  {% comment %} ============ COMMUNITY ============ {% endcomment %}
  <section class="bnj-community" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/Blessed_Hoops_Grassroots.jpg?v=1776331560');">
