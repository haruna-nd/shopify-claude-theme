{% comment %}
  ============================================================
  BLESSED SPORTSWEAR · Brand Page Template (v2)
  ============================================================
  FILE NAME:   page.its-not-just-a-brand.liquid
  LOCATION:    /templates/
{% endcomment %}

{{ 'its-not-just-a-brand.css' | asset_url | stylesheet_tag }}

<div class="bnj-page">

  {% comment %} ============ HERO ============ {% endcomment %}
  <section class="bnj-hero">
    <div class="bnj-hero__inner">
      <div class="bnj-hero__content">
        <div class="bnj-eyebrow">Athlete Born. Community Driven.</div>
        <h1 class="bnj-hero__headline">
          WEAR<br>
          <span class="bnj-italic">The</span><br>
          WORK.
        </h1>
        <p class="bnj-hero__deck">
          Premium sportswear for the ones who show up first and leave last. Born from real basketball camps and athlete development programs. Made for the work nobody sees.
        </p>
        <div class="bnj-hero__cta-row">
          <a href="/collections/all" class="bnj-btn bnj-btn--primary">
            Shop The Collection
            <span class="bnj-arrow">→</span>
          </a>
        </div>
        <div class="bnj-hero__meta">
          <span>Free US Shipping $120+</span>
          <span class="bnj-divider"></span>
          <span>60 Day Returns</span>
        </div>
      </div>

      <div class="bnj-hero__visual">
        <div class="bnj-hero__image" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/About_Us_Hero_IMG.png?v=1776685990');">
        </div>
        <div class="bnj-hero__tag">Spring Drop · 2026</div>
      </div>
    </div>
  </section>

  {% comment %} ============ MISSION ============ {% endcomment %}
  <section class="bnj-mission">
    <div class="bnj-container bnj-container--narrow">
      <div class="bnj-eyebrow bnj-eyebrow--center">Our Belief</div>
      <p class="bnj-mission__text">
        For every athlete grinding before sunrise, for every name not yet known, for every quiet rep that builds a loud life.
        <span class="bnj-italic">Blessed is for you.</span>
      </p>
    </div>
  </section>

  {% comment %} ============ STORIES ============ {% endcomment %}
  <section class="bnj-stories">
    <div class="bnj-container">
      <div class="bnj-section-header">
        <div class="bnj-eyebrow bnj-eyebrow--center">The Family</div>
        <h2 class="bnj-section-headline">
          WORN BY <span class="bnj-italic">Athletes</span><br>
          WHO SHOW UP.
        </h2>
        <p class="bnj-section-deck">From morning shoot arounds to weekend rec leagues, this is who we build for. The disciplined. The consistent. The ones putting in the work.</p>
      </div>

      <div class="bnj-stories__grid">
        <div class="bnj-story" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/2025-11-01-SBL-Nyon-Massagno-049_1.jpg?v=1776683688');">
          <div class="bnj-story__overlay"></div>
          <div class="bnj-story__content">
            <small>The Court</small>
            <h3>SBL Nyon</h3>
          </div>
        </div>
        <div class="bnj-story" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/Blessed_Hoops_Grassroots.jpg?v=1776331560');">
          <div class="bnj-story__overlay"></div>
          <div class="bnj-story__content">
            <small>Grassroots</small>
            <h3>The Program</h3>
          </div>
        </div>
        <div class="bnj-story" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/SnapInsta.to_528303264_18319436320210574_2869901680635848121_n.jpg?v=1776332074');">
          <div class="bnj-story__overlay"></div>
          <div class="bnj-story__content">
            <small>Training</small>
            <h3>The Work</h3>
          </div>
        </div>
        <div class="bnj-story" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/SnapInsta.to_528744796_18495878866064562_1841576174132476192_n.jpg?v=1776332236');">
          <div class="bnj-story__overlay"></div>
          <div class="bnj-story__content">
            <small>Off Court</small>
            <h3>The Family</h3>
          </div>
        </div>
      </div>
    </div>
  </section>

  {% comment %} ============ COLLECTION (3 FEATURED PRODUCTS - EDITORIAL) ============ {% endcomment %}
  <section class="bnj-collection">
    <div class="bnj-container">
      <div class="bnj-section-header">
        <div class="bnj-eyebrow bnj-eyebrow--center">The Pieces</div>
        <h2 class="bnj-section-headline">
          BUILT FOR THE <span class="bnj-italic">Everyday</span><br>
          GRIND.
        </h2>
        <p class="bnj-section-deck">Three pieces from the family. Heavyweight builds. Premium feel. Made to live in.</p>
      </div>

      {%- assign product_handles = "oversized-hoodie-ivory,oversized-hoodie-slate,core-hoodie-ash" | split: "," -%}
      <div class="bnj-editorial-products">
        {%- for handle in product_handles -%}
          {%- assign product = all_products[handle] -%}
          {%- if product.id -%}
            <div class="bnj-editorial-product {% cycle 'is-left', 'is-right', 'is-left' %}">
              <a href="{{ product.url }}" class="bnj-editorial-product__image">
                {%- if product.featured_image -%}
                  <img src="{{ product.featured_image | image_url: width: 1000 }}" alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="1000" height="1250">
                {%- endif -%}
                {%- if product.tags contains 'bestseller' -%}
                  <span class="bnj-editorial-product__tag">Bestseller</span>
                {%- elsif product.tags contains 'new' -%}
                  <span class="bnj-editorial-product__tag">New</span>
                {%- endif -%}
              </a>
              <div class="bnj-editorial-product__info">
                <div class="bnj-editorial-product__num">{{ forloop.index | prepend: "0" }}</div>
                <div class="bnj-editorial-product__eyebrow">Featured Piece</div>
                <h3 class="bnj-editorial-product__title">{{ product.title }}</h3>
                {%- if product.description != blank -%}
                  <p class="bnj-editorial-product__desc">{{ product.description | strip_html | truncate: 200 }}</p>
                {%- else -%}
                  <p class="bnj-editorial-product__desc">Premium heavyweight build. Designed to live in. Made for the work nobody sees.</p>
                {%- endif -%}
                <div class="bnj-editorial-product__price-row">
                  <p class="bnj-editorial-product__price">
                    {%- if product.compare_at_price > product.price -%}
                      <span class="bnj-editorial-product__price-sale">{{ product.price | money }}</span>
                      <span class="bnj-editorial-product__price-was">{{ product.compare_at_price | money }}</span>
                    {%- else -%}
                      {{ product.price | money }}
                    {%- endif -%}
                  </p>
                  <a href="{{ product.url }}" class="bnj-btn bnj-btn--primary">
                    Shop Now
                    <span class="bnj-arrow">→</span>
                  </a>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="bnj-collection__cta">
        <a href="/collections/all" class="bnj-btn bnj-btn--secondary">
          Shop The Full Collection
          <span class="bnj-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  {% comment %} ============ ORIGIN STORY ============ {% endcomment %}
  <section class="bnj-origin">
    <div class="bnj-container">
      <div class="bnj-origin__grid">
        <div class="bnj-origin__image" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/SnapInsta.to_571743594_18328902472210574_3464873837099798509_n.webp?v=1776333351');">
        </div>
        <div class="bnj-origin__content">
          <div class="bnj-eyebrow">Our Roots</div>
          <h2 class="bnj-origin__headline">
            BUILT IN THE <span class="bnj-italic">Gym,</span><br>
            NOT THE BOARDROOM.
          </h2>
          <p>Blessed didn't start in a fashion office. It started on a hardwood floor at Blessed Hoops, between drills, during the kind of conversations that happen when sweat dries and athletes talk about who they really want to become.</p>
          <p>We run real basketball camps, mentor real athletes, and watch real transformation happen in places most brands never visit. The clothing came after. It had to. Because the athletes we work with deserved gear that actually represented them.</p>
          <p>Born in sport. Built for the streets. Every hoodie, every set, every tee carries that origin. This isn't a brand built to sell to athletes. It's a brand built by people who train alongside them.</p>
          <div class="bnj-origin__tag">
            <span class="bnj-origin__tag-label">Since Day One</span>
            <span class="bnj-origin__tag-text">Camps. Clubs. Community.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {% comment %} ============ EDITORIAL SPLIT 01 ============ {% endcomment %}
  <section class="bnj-split">
    <div class="bnj-split__image" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/anelissaphoto_3of52.jpg?v=1777628657');"></div>
    <div class="bnj-split__image" style="background-image: url('https://cdn.shopify.com/s/files/1/0726/4210/1338/files/STR_blessedMark-6_1.jpg?v=1776674873');"></div>
  </section>

  {% comment %} ============ VIDEO ============ {% endcomment %}
  <section class="bnj-video">
    <div class="bnj-video__inner">
      <div class="bnj-video__header">
        <div class="bnj-eyebrow bnj-eyebrow--center">In Motion</div>
