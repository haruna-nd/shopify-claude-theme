          SEE THE WORK<br>
          <span class="bnj-italic">In Motion.</span>
        </h2>
      </div>
      <div class="bnj-video__player" data-bnj-video>
        <video
          class="bnj-video__el"
          preload="metadata"
          playsinline
          muted
          loop
          poster="https://cdn.shopify.com/s/files/1/0726/4210/1338/files/About_Us_Hero_IMG.png?v=1776685990"
          data-bnj-video-el
        >
          <source src="https://cdn.shopify.com/videos/c/o/v/c918e75560454bd68b0c556e6da38afc.mp4" type="video/mp4">
          Your browser does not support video.
        </video>
        <button class="bnj-video__play" aria-label="Play video" data-bnj-video-trigger>
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
        </button>
      </div>
    </div>
  </section>

  {% comment %} ============ STORIES IN MOTION (REELS) ============ {% endcomment %}
  <section class="bnj-reels">
    <div class="bnj-container">
      <div class="bnj-section-header">
        <div class="bnj-eyebrow bnj-eyebrow--center">Stories In Motion</div>
