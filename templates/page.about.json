        "pillar_2": {
          "type": "pillar",
          "settings": {
            "title": "The Breakthrough",
            "text": "Every grinder has a moment when it clicks. A call-up. A contract. A door that opens because you were ready when it did. Blessed is for that moment, and everything you sacrificed to get there."
          }
        },
        "pillar_3": {
          "type": "pillar",
          "settings": {
            "title": "The Gratitude",
            "text": "When it happens, you don't forget where you came from. That's what \"blessed\" means. Not luck. Earned grace. A quiet acknowledgement that the work was worth it, and something greater had a hand in it."
          }
        },
        "pillar_4": {
          "type": "pillar",
          "settings": {
            "title": "The Quiet",
            "text": "No hype. No noise. Just quality, intention, and an identity that doesn't need to announce itself. The people who know, know."
          }
        }
