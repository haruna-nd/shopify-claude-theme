

<section class="blessed-email-capture">
  <div class="blessed-container">
    <div class="blessed-email-capture__inner">
      <div class="blessed-email-capture__left">
        <h2 style="font-family:var(--font-display); font-size:clamp(42px,4vw,60px); color:var(--white); letter-spacing:0.04em; line-height:0.95; margin-bottom:20px;">
          {{ section.settings.heading | default: 'Stay In The Loop' }}
        </h2>
        <p class="blessed-email-capture__desc">{{ section.settings.description | default: 'New drops, exclusive access, and athletes-only content — straight to your inbox.' }}</p>
        <div class="blessed-email-capture__perks">
          {% for block in section.blocks %}
            {% if block.type == 'perk' %}
              <div class="blessed-email-capture__perk" {{ block.shopify_attributes }}>
                <span class="blessed-email-capture__perk-dot"></span>
                {{ block.settings.text }}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="blessed-email-capture__form-col">
        {% form 'customer', id: 'blessed-newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="blessed-email-capture__form">
            <div class="blessed-email-capture__input-wrap">
              <input
                type="email"
                name="contact[email]"
                class="blessed-email-capture__input"
                placeholder="{{ section.settings.placeholder | default: 'Your email address' }}"
                required
                autocomplete="email"
                aria-label="Email address"
              >
              <button type="submit" class="blessed-email-capture__submit">
                {{ section.settings.button_label | default: 'Subscribe' }}
              </button>
            </div>
            <p class="blessed-email-capture__note">{{ section.settings.note | default: 'No spam. Unsubscribe any time. We respect your privacy.' }}</p>
          </div>
          {% if form.posted_successfully? %}
            <p style="color:var(--accent); font-size:13px; letter-spacing:0.06em; margin-top:12px;">You\'re in. Welcome to the movement.</p>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Email Capture",
  "tag": "div",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Stay In The Loop"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "New drops, exclusive access, and athletes-only content — straight to your inbox."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input Placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Fine Print",
      "default": "No spam. Unsubscribe any time. We respect your privacy."
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "Perk",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Perk Text",
          "default": "Early access to new drops"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Email Capture",
      "blocks": [
        { "type": "perk", "settings": { "text": "Early access to new drops" } },
        { "type": "perk", "settings": { "text": "Exclusive athlete discounts" } },
        { "type": "perk", "settings": { "text": "Behind-the-scenes content" } }
      ]
    }
  ]
}
{% endschema %}
