<script>
(function() {
  'use strict';

  document.addEventListener('click', function(e) {
    var faqQ = e.target.closest('.bnj-faq__q');
    if (faqQ) {
      var item = faqQ.closest('.bnj-faq__item');
      if (item) item.classList.toggle('is-open');
    }
  });

  var videoBtns = document.querySelectorAll('[data-bnj-video-trigger]');
  videoBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var wrap = btn.closest('[data-bnj-video]');
      if (!wrap) return;
      var video = wrap.querySelector('[data-bnj-video-el]');
      if (!video) return;
      if (video.paused) {
        video.muted = false;
        video.controls = true;
        video.play();
        wrap.classList.add('is-playing');
      } else {
        video.pause();
        wrap.classList.remove('is-playing');
      }
    });
  });

  var reelBtns = document.querySelectorAll('[data-bnj-reel-trigger]');
  reelBtns.forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var wrap = btn.closest('[data-bnj-reel]');
      if (!wrap) return;
      var video = wrap.querySelector('[data-bnj-reel-el]');
      if (!video) return;

      document.querySelectorAll('[data-bnj-reel]').forEach(function(other) {
        if (other !== wrap) {
          var otherVid = other.querySelector('[data-bnj-reel-el]');
          if (otherVid && !otherVid.paused) {
            otherVid.pause();
            otherVid.muted = true;
            otherVid.controls = false;
            other.classList.remove('is-playing');
          }
        }
      });

      if (video.paused) {
        video.muted = false;
        video.controls = true;
        video.play();
        wrap.classList.add('is-playing');
      } else {
        video.pause();
        video.muted = true;
        video.controls = false;
        wrap.classList.remove('is-playing');
      }
    });
  });

  var reels = document.querySelectorAll('[data-bnj-reel]');
  reels.forEach(function(reel) {
    var video = reel.querySelector('[data-bnj-reel-el]');
    if (!video) return;
    reel.addEventListener('mouseenter', function() {
      if (window.innerWidth > 900 && !reel.classList.contains('is-playing')) {
        video.play().catch(function() {});
      }
    });
    reel.addEventListener('mouseleave', function() {
      if (!reel.classList.contains('is-playing')) {
        video.pause();
        video.currentTime = 0;
      }
    });
  });

  if ('IntersectionObserver' in window) {
    var revealEls = document.querySelectorAll('.bnj-page .bnj-section-headline, .bnj-page .bnj-mission__text, .bnj-page .bnj-origin__grid, .bnj-page .bnj-reel, .bnj-page .bnj-pillar, .bnj-page .bnj-quote__inner, .bnj-page .bnj-product, .bnj-page .bnj-testimonial, .bnj-page .bnj-faq__item, .bnj-page .bnj-final__inner');
    revealEls.forEach(function(el) { el.classList.add('bnj-reveal'); });

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -60px 0px' });

    revealEls.forEach(function(el) { observer.observe(el); });
  }
})();
</script>