  {% comment %} ============ FAQ ============ {% endcomment %}
  <section class="bnj-faq">
    <div class="bnj-container bnj-container--narrow">
      <div class="bnj-section-header">
        <div class="bnj-eyebrow bnj-eyebrow--center">Common Questions</div>
        <h2 class="bnj-section-headline">
          THINGS YOU<br>
          MIGHT BE <span class="bnj-italic">Wondering.</span>
        </h2>
      </div>

      <div class="bnj-faq__list" data-bnj-faq>
        <div class="bnj-faq__item is-open">
          <button class="bnj-faq__q" type="button">
            <span>How long does shipping take to the US?</span>
            <span class="bnj-faq__toggle"></span>
          </button>
          <div class="bnj-faq__a">
            <div class="bnj-faq__a-inner">7 to 10 business days from order to door. Free on US orders over $120. Tracking sent the moment your order leaves the warehouse.</div>
          </div>
        </div>
        <div class="bnj-faq__item">
          <button class="bnj-faq__q" type="button">
            <span>What is your return policy?</span>
            <span class="bnj-faq__toggle"></span>
          </button>
          <div class="bnj-faq__a">
            <div class="bnj-faq__a-inner">60 days. Free returns through our US partner. If the fit isn't right or you change your mind, send it back for a full refund.</div>
          </div>
        </div>
        <div class="bnj-faq__item">
          <button class="bnj-faq__q" type="button">
            <span>Will I be charged customs fees?</span>
            <span class="bnj-faq__toggle"></span>
          </button>
          <div class="bnj-faq__a">
            <div class="bnj-faq__a-inner">No. Blessed handles all duties on US orders. The price you see at checkout is exactly what you pay. Nothing extra at the door.</div>
          </div>
        </div>
        <div class="bnj-faq__item">
          <button class="bnj-faq__q" type="button">
            <span>How does the fit run?</span>
            <span class="bnj-faq__toggle"></span>
          </button>
          <div class="bnj-faq__a">
            <div class="bnj-faq__a-inner">True to size for an intentionally relaxed cut. If you prefer a more standard fit, size down one. Detailed size chart on every product page.</div>
          </div>
        </div>
        <div class="bnj-faq__item">
          <button class="bnj-faq__q" type="button">
            <span>Do you offer custom team apparel?</span>
            <span class="bnj-faq__toggle"></span>
          </button>
          <div class="bnj-faq__a">
            <div class="bnj-faq__a-inner">Yes. We offer custom branding and printing for clubs, schools, and grassroots teams. Reach out through our contact page with your team details.</div>
          </div>
        </div>
      </div>
    </div>
