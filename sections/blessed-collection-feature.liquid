

<div class="blessed-collection-feature">
  {% for block in section.blocks %}
    {% if block.type == 'panel' %}
      <div class="blessed-collection-panel" {{ block.shopify_attributes }}>
        <div class="blessed-collection-panel__bg">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1200
              | image_tag:
                class: 'blessed-collection-panel__img',
                loading: 'lazy',
                widths: '600, 900, 1200'
            }}
          {% endif %}
        </div>
        <div class="blessed-collection-panel__overlay"></div>
        {% if block.settings.collection_name != blank %}
          <div class="blessed-collection-panel__ghost">{{ block.settings.collection_name }}</div>
        {% endif %}
        <div class="blessed-collection-panel__content">
          {% if block.settings.eyebrow != blank %}
            <div class="blessed-collection-panel__eyebrow">{{ block.settings.eyebrow }}</div>
          {% endif %}
          {% if block.settings.collection_name != blank %}
            <h2 class="blessed-collection-panel__name">{{ block.settings.collection_name }}</h2>
          {% endif %}
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="blessed-collection-panel__link">Explore Collection</a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
</div>

{% schema %}
{
  "name": "Collection Feature Panels",
  "tag": "div",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "blocks": [
    {
      "type": "panel",
      "name": "Collection Panel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text",
          "default": "New Season"
        },
        {
          "type": "text",
          "id": "collection_name",
          "label": "Collection Name",
          "default": "The Grind"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Feature Panels",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "eyebrow": "New Season",
            "collection_name": "The Grind"
          }
        },
        {
          "type": "panel",
          "settings": {
            "eyebrow": "Limited Drop",
            "collection_name": "The Blessed"
          }
        }
      ]
    }
  ]
}
{% endschema %}
